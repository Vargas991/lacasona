generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WAITER
  KITCHEN
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  BILLING
  DISABLED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
}

enum PaymentMethod {
  CASH
  CARD
  CASH_COP
  BOLIVARES
  POS
  MOBILE_PAYMENT
  USD
  ZELLE
  BANCOLOMBIA
}

enum PaymentCurrency {
  COP
  BS
  USD
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING
  SALE_TENDERED
  CHANGE_GIVEN
  MANUAL_INCOME
  EXPENSE
  EXCHANGE_IN
  EXCHANGE_OUT
  CLOSING_ADJUSTMENT
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         Role
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orders       Order[]
  payments     Payment[]
  cashSessions CashSession[] @relation("CashSessionCashier")
  closedCashSessions CashSession[] @relation("CashSessionClosedBy")
  cashMovements CashMovement[] @relation("CashMovementCreatedBy")
}

model Table {
  id          String      @id @default(cuid())
  name        String      @unique
  capacity    Int
  zone        String      @default("Salon")
  layoutX     Int         @default(50)
  layoutY     Int         @default(50)
  status      TableStatus @default(FREE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orders      Order[]
  reservations Reservation[]
  cashMovements CashMovement[]
}

model Reservation {
  id           String   @id @default(cuid())
  guestName    String
  guestCount   Int
  reservationAt DateTime
  notes        String?
  tableId      String
  table        Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  isPackaging Boolean   @default(false)
  products    Product[]
}

model DailyCounter {
  dateKey         String @id
  lastOrderNumber Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DashboardSettings {
  id                String   @id
  copToBsDivisor    Decimal  @db.Decimal(10, 4)
  copToUsdDivisor   Decimal  @db.Decimal(12, 4)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  isActive    Boolean     @default(true)
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems  OrderItem[]
}

model Order {
  id         String      @id @default(cuid())
  tableId    String
  waiterId   String
  dateKey    String
  dailySequence Int
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  closedAt   DateTime?
  deliveryAddress String?
  isDelivery  Boolean     @default(false)
  table      Table       @relation(fields: [tableId], references: [id])
  waiter     User        @relation(fields: [waiterId], references: [id])
  items      OrderItem[]
  payment    Payment?
  cashMovements CashMovement[]

  @@unique([dateKey, dailySequence])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  note        String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  cashierId String
  cashSessionId String?
  method    PaymentMethod
  subtotal  Decimal       @db.Decimal(10, 2)
  tax       Decimal       @db.Decimal(10, 2)
  total     Decimal       @db.Decimal(10, 2)
  paidCurrency PaymentCurrency @default(COP)
  paidAmount Decimal?      @db.Decimal(12, 2)
  copToBsDivisorSnapshot  Decimal? @db.Decimal(10, 4)
  copToUsdDivisorSnapshot Decimal? @db.Decimal(12, 4)
  paidAt    DateTime      @default(now())
  order     Order         @relation(fields: [orderId], references: [id])
  cashier   User          @relation(fields: [cashierId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  cashMovements CashMovement[]
}

model CashSession {
  id          String            @id @default(cuid())
  cashierId   String
  closedById  String?
  status      CashSessionStatus @default(OPEN)
  openingCurrency PaymentCurrency
  openingAmount Decimal         @db.Decimal(12, 2)
  openingCopToBsDivisor Decimal @db.Decimal(10, 4)
  openingCopToUsdDivisor Decimal @db.Decimal(12, 4)
  expectedCopAtClose Decimal?   @db.Decimal(12, 2)
  expectedBsAtClose Decimal?    @db.Decimal(12, 2)
  expectedUsdAtClose Decimal?   @db.Decimal(12, 2)
  countedCop Decimal?           @db.Decimal(12, 2)
  countedBs Decimal?            @db.Decimal(12, 2)
  countedUsd Decimal?           @db.Decimal(12, 2)
  differenceCop Decimal?        @db.Decimal(12, 2)
  differenceBs Decimal?         @db.Decimal(12, 2)
  differenceUsd Decimal?        @db.Decimal(12, 2)
  openingNote String?
  closingNote String?
  openedAt    DateTime          @default(now())
  closedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  cashier     User              @relation("CashSessionCashier", fields: [cashierId], references: [id])
  closedBy    User?             @relation("CashSessionClosedBy", fields: [closedById], references: [id])
  payments    Payment[]
  movements   CashMovement[]

  @@index([cashierId, status])
}

model CashMovement {
  id          String           @id @default(cuid())
  cashSessionId String
  createdById String
  tableId     String?
  orderId     String?
  paymentId   String?
  type        CashMovementType
  currency    PaymentCurrency
  amount      Decimal          @db.Decimal(12, 2)
  paymentMethod PaymentMethod?
  relatedCurrency PaymentCurrency?
  relatedAmount Decimal?       @db.Decimal(12, 2)
  copToBsDivisorSnapshot Decimal? @db.Decimal(10, 4)
  copToUsdDivisorSnapshot Decimal? @db.Decimal(12, 4)
  note        String?
  createdAt   DateTime         @default(now())
  cashSession CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("CashMovementCreatedBy", fields: [createdById], references: [id])
  table       Table?           @relation(fields: [tableId], references: [id])
  order       Order?           @relation(fields: [orderId], references: [id])
  payment     Payment?         @relation(fields: [paymentId], references: [id])

  @@index([cashSessionId, createdAt])
}
