{
  "name": "lacasona-pos",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run start:dev",
    "dev:frontend": "npm --workspace apps/frontend run dev -- --host 0.0.0.0 --port 5173",
    "preview:frontend": "npm --workspace apps/frontend run preview -- --host 0.0.0.0 --port 4173",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm --workspace apps/backend run build",
    "build:frontend": "npm --workspace apps/frontend run build",
    "prisma:migrate": "npm --workspace apps/backend run prisma:migrate",
    "prisma:generate": "npm --workspace apps/backend run prisma:generate",
    "prisma:seed": "npm --workspace apps/backend run prisma:seed"
  }
}
